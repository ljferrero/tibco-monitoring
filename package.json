{
  "name": "bwce.monitoring.package",
  "version": "1.0.0",
  "description": "Application monitoring for TIBCO BusinessWorks Container Edition",
  "main": "/",
  "scripts": {
    "start": "NODE_ENV=dev PORT=8080 node server/node-server.js",
    "test": "karma start --NODE_ENV=test",
    "build": "webpack --config webpack/webpack.build.js --NODE_ENV=production",
    "dev:server": "cross-env NODE_ENV=dev PORT=8080 node server/node-server.js",
    "dev:client": "cross-env NODE_ENV=dev webpack-dev-server --config webpack/webpack.dev.js -d --inline --progress --no-info",
    "dev": "concurrently -r \"npm run dev:server\" \"webpack --config webpack/webpack.dev.js --watch --NODE_ENV=dev\"",
    "dist": "npm install && npm run build && npm pack"
  },
